# ──────────────────────────────────────────────────────────────────────────────
# Pulse — environment template
#
# Copy to `.env` and fill in values. NEVER commit a real .env file.
# Generate strong secrets automatically with:  npm run secrets
# ──────────────────────────────────────────────────────────────────────────────

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── Database (CRM API) ────────────────────────────────────────────────────────
# Local: docker compose up -d   |   Prod: Neon/Supabase connection string (sslmode=require)
DATABASE_URL=postgresql://pulse:pulse@localhost:5432/pulse

# ── Redis (BullMQ queue) ──────────────────────────────────────────────────────
# Local: docker compose up -d   |   Prod: Upstash Redis URL (rediss://, TLS)
REDIS_URL=redis://localhost:6379

# ── Service URLs ──────────────────────────────────────────────────────────────
CRM_API_PORT=4000
SIMULATOR_PORT=4100
# Public base URL of the CRM API — the simulator posts delivery receipts here
CRM_PUBLIC_URL=http://localhost:4000
# Base URL of the channel simulator — the CRM worker sends messages here
SIMULATOR_URL=http://localhost:4100
# Web app origin, used for the CRM API CORS allowlist
WEB_ORIGIN=http://localhost:3000
# CRM API base URL as seen by the web app's server-side routes
CRM_API_URL=http://localhost:4000

# ── Secrets (generate with: npm run secrets) ─────────────────────────────────
# API key required on every CRM write endpoint (x-api-key). Min 32 chars.
PULSE_API_KEY=
# Shared secret for HMAC-SHA256 request signing between CRM ⇄ Simulator. Min 32 chars.
WEBHOOK_HMAC_SECRET=
# AES-256-GCM key for PII-at-rest encryption (base64-encoded, exactly 32 bytes).
PII_ENCRYPTION_KEY=
# HMAC key for PII blind indexes (search/dedupe without decryption). Min 32 chars.
PII_HASH_KEY=
# Admin key for the simulator chaos/config endpoints. Min 32 chars.
SIMULATOR_ADMIN_KEY=

# ── Simulator callback security ───────────────────────────────────────────────
# Comma-separated origins the simulator may POST callbacks to (SSRF guard).
CALLBACK_ALLOWLIST=http://localhost:4000

# ── Web workspace access (Phase 3) ───────────────────────────────────────────
# Set to gate the web app behind a login (recommended for hosted deploys).
# Leave empty for an open local dev workspace. Min 8 chars.
PULSE_ACCESS_CODE=
# Signs session cookies; falls back to PULSE_ACCESS_CODE when empty.
PULSE_SESSION_SECRET=
# Set to "true" to display the access code ON the login screen (judged demo
# deploys — zero reviewer friction; the session gate still keeps bots out).
PULSE_SHOW_ACCESS_CODE=

# ── AI layer (Phase 2) ────────────────────────────────────────────────────────
# Set ANY of these keys — they form a failover CHAIN, free tiers first:
#   openrouter → gemini → groq → anthropic
# A rate-limited leg cools down 5 minutes and the next one serves. With no
# keys at all, the AI endpoints return 503 and everything else keeps working.
# Force the primary leg with AI_PROVIDER=openrouter|gemini|groq|anthropic.
#
# Free keys (no card needed):
#   OpenRouter — https://openrouter.ai/keys        (~50 free-model req/day)
#   Gemini     — https://aistudio.google.com/apikey (Google AI Studio free tier)
#   Groq       — https://console.groq.com/keys     (free tier)
OPENROUTER_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=
# Optional overrides (sensible per-provider defaults apply):
AI_PROVIDER=
AI_MODEL=
AI_FALLBACK_MODELS=
