{
  "name": "@pulse/crm-api",
  "version": "0.1.0",
  "private": true,
  "description": "Pulse CRM API — ingest, segments, campaigns, receipts, insights. NestJS + Prisma + BullMQ.",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
