    "@nestjs/throttler": "^6.3.0",
    "@prisma/client": "^6.2.1",
    "@pulse/shared": "*",
    "bullmq": "^5.34.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "ioredis": "5.10.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.3.0",
    "@nestjs/cli": "^11.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "prisma": "^6.2.1",
