// Pulse data model v1.
//
// Security notes:
//  - Customer PII (email, phone) is encrypted at rest with AES-256-GCM.
//    The *_enc columns hold versioned ciphertext (`v1:<iv>:<tag>:<ct>`);
//    email_hash is an HMAC-SHA256 blind index for lookups without decryption.
//  - comm_events is append-only and is the source of truth; campaign
//    aggregates are derived and can always be recomputed from it.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id          String    @id @default(uuid())
  externalId  String    @unique @map("external_id")
  name        String
  emailEnc    String?   @map("email_enc")
  emailHash   String?   @map("email_hash")
  phoneEnc    String?   @map("phone_enc")
  city        String?
  tags        String[]  @default([])
  // Denormalized rollups, recomputed from orders on every ingest (idempotent).
  totalSpend  Decimal   @default(0) @map("total_spend") @db.Decimal(12, 2)
  orderCount  Int       @default(0) @map("order_count")
  lastOrderAt DateTime? @map("last_order_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  orders         Order[]
  communications Communication[]

  @@index([emailHash])
  @@index([totalSpend])
  @@index([orderCount])
  @@index([lastOrderAt])
  @@index([city])
  @@map("customers")
}

model Order {
  id                        String   @id @default(uuid())
  externalId                String   @unique @map("external_id")
  customerId                String   @map("customer_id")
  customer                  Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  amount                    Decimal  @db.Decimal(12, 2)
  items                     Json     @default("[]")
  orderedAt                 DateTime @map("ordered_at")
  source                    String   @default("api")
  // Set by the attribution job (Phase 3) when an order follows a click/read.
  attributedCommunicationId String?  @map("attributed_communication_id")
  createdAt                 DateTime @default(now()) @map("created_at")

  @@index([customerId])
  @@index([orderedAt])
  @@map("orders")
}

model Segment {
  id          String     @id @default(uuid())
  name        String
  dslJson     Json       @map("dsl_json")
  createdFrom String     @default("manual") @map("created_from") // "nl" | "manual"
  nlPrompt    String?    @map("nl_prompt")
  createdAt   DateTime   @default(now()) @map("created_at")
  campaigns   Campaign[]

  @@map("segments")
}

enum CampaignStatus {
  DRAFT
  RUNNING
  COMPLETED
}

enum Channel {
  whatsapp
  sms
  email
  rcs
}

enum CommunicationStatus {
  QUEUED
  SENT
  FAILED
  DELIVERED
  OPENED
  READ
  CLICKED
  CONVERTED
}

model Campaign {
  id                    String         @id @default(uuid())
  name                  String
  segmentId             String?        @map("segment_id")
  segment               Segment?       @relation(fields: [segmentId], references: [id])
  objective             String?
  // { primary, failover: [channel...], failoverWindowMinutes }
  channelPolicy         Json           @map("channel_policy")
  // Raw audience filters for Phase 1 launches (segments arrive in Phase 2).
  audienceJson          Json?          @map("audience_json")
  messageTemplate       String         @map("message_template")
  status                CampaignStatus @default(DRAFT)
  audienceSnapshotCount Int            @default(0) @map("audience_snapshot_count")
  createdAt             DateTime       @default(now()) @map("created_at")
  launchedAt            DateTime?      @map("launched_at")

  communications Communication[]

  @@index([status])
  @@map("campaigns")
}

model Communication {
  id                    String              @id @default(uuid())
  campaignId            String              @map("campaign_id")
  campaign              Campaign            @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customerId            String              @map("customer_id")
  customer              Customer            @relation(fields: [customerId], references: [id], onDelete: Cascade)
  channel               Channel
  messageRendered       String              @map("message_rendered")
  status                CommunicationStatus @default(QUEUED)
  // Mirrors STATUS_RANK in @pulse/shared — state only ever moves to a higher rank.
  statusRank            Int                 @default(0) @map("status_rank")
  attempt               Int                 @default(0)
  // Links a failover retry to the communication it escalated from.
  parentCommunicationId String?             @map("parent_communication_id")
  vendorMessageId       String?             @map("vendor_message_id")
  failureReason         String?             @map("failure_reason")
  sentAt                DateTime?           @map("sent_at")
  lastEventAt           DateTime?           @map("last_event_at")
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")

  events CommEvent[]

  @@index([campaignId, status])
  @@index([customerId])
  @@index([status])
  @@map("communications")
}

model CommEvent {
  id              String        @id @default(uuid())
  communicationId String        @map("communication_id")
  communication   Communication @relation(fields: [communicationId], references: [id], onDelete: Cascade)
  eventType       String        @map("event_type")
  eventTs         DateTime      @map("event_ts")
  payload         Json?
  // `${message_id}:${event_type}` — duplicate callbacks collide here and are dropped.
  idempotencyKey  String        @unique @map("idempotency_key")
  receivedAt      DateTime      @default(now()) @map("received_at")

  @@index([communicationId])
  @@index([eventType])
  @@map("comm_events")
}
